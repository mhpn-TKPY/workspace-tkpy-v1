{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/apps/shop/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1",
    "SKIP_API_CALLS": "true"
  },
  "functions": {
    "apps/api/dist/main.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/api/dist/main.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/apps/shop/server/server.mjs"
    }
  ]
}
{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/apps/shop/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1",
    "SKIP_API_CALLS": "true"
  },
  "builds": [
    {
      "src": "dist/apps/api/main.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/apps/shop/browser/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "dist/apps/shop/server/server.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/apps/api/main.js"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|woff2?|ttf|eot))$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/dist/apps/shop/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/apps/shop/server/server.mjs"
    }
  ]
}
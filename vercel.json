{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/apps/shop/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npx nx serve shop",
  "framework": null,
  "regions": [
    "iad1"
  ],
  "functions": {
    "dist/apps/shop/server/server.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/apps/shop/server/server.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/apps/shop/browser/$1"
    }
  ]
}